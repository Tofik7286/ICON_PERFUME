.env
.env.*
*.env
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
*.der

# AWS / Cloud credentials

.aws/
.aws-config/
.aws/credentials
.aws/config

# SSH Keys

id_rsa
id_rsa.pub
*.pem

