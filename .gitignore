# 🐍 Django / Python

# ------------------------------------------

*.log
*.pot
*.pyc
*.pyo
*.pyd
**pycache**/
*$py.class

db.sqlite3
db.sqlite3-journal
backend/tempdb.sqlite3

# Django local settings

local_settings.py

# Virtual environments

.venv/
venv/
env/
ENV/

# ------------------------------------------

